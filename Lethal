        for i = 6, 1, -1 do
            r = r .. (f % 2 ^ i - f % 2 ^ (i - 1) > 0 and '1' or '0')
        end
        return r
    end):gsub('%d%d%d%d%d%d%d%d', function(x)
        local n = 0
        x:gsub('.', function(c)
            n = n * 2 + (c == '1' and 1 or 0)
        end)
        s = s .. string.char(n)
        return ''
    end) and s)
end

